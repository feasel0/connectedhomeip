import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")

import("${chip_root}/build/chip/chip_test.gni")
import("${chip_root}/build/chip/tests.gni")
import("${dir_pw_unit_test}/test.gni")

if (chip_device_platform == "efr32") {
  import("//platform_executable_args.gni")
}

# Set the platform-specific executable type.
if (defined(platform_executable_type)) {
  pw_unit_test_EXECUTABLE_TARGET_TYPE = platform_executable_type
}
if (defined(platform_executable_type_file)) {
  pw_unit_test_EXECUTABLE_TARGET_TYPE_FILE = platform_executable_type_file
}

assert(chip_build_tests)

# Define CHIP unit tests
#
# Simple usage
# chip_test_suite("tests") {
#   output_name = "libFooTests"
#
#   sources = [
#      "Common.h",      # add common sources here
#      "Common.cpp",
#   ]
#
#   test_sources = [
#     "TestFoo.cpp",
#     "TestBar.cpp",
#   ]
#
#   public_deps = [
#     "${chip_root}/src/lib/foo",         # add dependencies here
#   ]
# }
#
#
# Deprecated usage (writing own driver files):
#
# chip_test_suite("tests") {
#   output_name = "libFooTests"
#
#   sources = [
#     "TestDeclarations.h",
#     "TestFoo.cpp",
#     "TestBar.cpp",
#   ]
#
#   public_deps = [
#     "${chip_root}/src/lib/foo",         # add dependencies here
#   ]
#
#   tests = [
#     "TestFoo",  # Assumes TestFooDriver.cpp exists
#     "TestBar",  # Assumes TestBarDriver.cpp exists
#   ]
# }

#
template("chip_test_suite") {
  _suite_name = target_name

  # Ensures that the common library has sources containing both common
  # and individual unit tests.
  if (!defined(invoker.sources)) {
    invoker.sources = []
  }

  if (defined(invoker.test_sources)) {
    invoker.sources += invoker.test_sources
  }

  if (chip_build_test_static_libraries) {
    _target_type = "static_library"
  } else {
    _target_type = "source_set"
  }
  target(_target_type, "${_suite_name}.lib") {
    forward_variables_from(invoker, "*", [ "tests" ])

    output_dir = "${root_out_dir}/lib"

    if (!defined(invoker.public_deps)) {
      public_deps = []
    }

    deps = [ dir_pw_unit_test ]

    if (current_os != "zephyr" && current_os != "mbed" &&
        chip_device_platform != "efr32") {
      # Depend on stdio logging, and have it take precedence over the default platform backend
      public_deps += [ "${chip_root}/src/platform/logging:stdio" ]
    } else {
      public_deps += [ "${chip_root}/src/platform/logging:default" ]
    }
  }
  if (chip_link_tests) {
    tests = []

    if (defined(invoker.test_sources)) {
      foreach(_test, invoker.test_sources) {
        _test_name = string_replace(_test, ".cpp", "")

        _test_output_dir = "${root_out_dir}/tests"
        if (defined(invoker.output_dir)) {
          _test_output_dir = invoker.output_dir
        }

        pw_test(_test_name) {
          forward_variables_from(invoker,
                                 [
                                   "deps",
                                   "public_deps",
                                   "cflags",
                                   "configs",
                                 ])
          public_deps += [ ":${_suite_name}.lib" ]
          sources = [ _test ]
          output_dir = _test_output_dir
        }
        tests += [ _test_name ]
      }
    }

    if (defined(invoker.tests)) {
      foreach(_test, invoker.tests) {
        _test_output_dir = "${root_out_dir}/tests"
        if (defined(invoker.output_dir)) {
          _test_output_dir = invoker.output_dir
        }

        pw_test(_test) {
          forward_variables_from(invoker,
                                 [
                                   "deps",
                                   "public_deps",
                                   "cflags",
                                   "configs",
                                 ])
          public_deps += [ ":${_suite_name}.lib" ]
          test_main = ""
          sources = [
            "${_test}.cpp",
            "${_test}Driver.cpp",
          ]
          output_dir = _test_output_dir
        }
        tests += [ _test ]
      }
    }

    group(_suite_name) {
      deps = []
      foreach(_test, tests) {
        deps += [ ":${_test}" ]
      }
    }

    if (chip_pw_run_tests) {
      group("${_suite_name}_run") {
        deps = []
        foreach(_test, tests) {
          deps += [ ":${_test}.run" ]
        }
      }
    }
  } else {

    # Specified a platform executable type.
    if (defined(platform_executable_output_name) && defined(invoker.test_sources)) {
      tests = []

      foreach(_test, invoker.test_sources) {
        _test_name = string_replace(_test, ".cpp", "")

        _test_output_dir = "${root_out_dir}/tests"
        if (defined(invoker.output_dir)) {
          _test_output_dir = invoker.output_dir
        }

        pw_test(_test_name) {
          # Forward certain varibles from the invoker
          _variables_from_invoker = [
            "deps",
            "public_deps",
            "cflags",
            "configs",
          ]
          forward_variables_from(invoker, _variables_from_invoker)

          # Initialize the variables that weren't defined in the invoker.
          if (!defined(deps)) { deps = [] }
          if (!defined(public_deps)) { public_deps = [] }
          if (!defined(cflags)) { cflags = [] }
          if (!defined(configs)) { configs = [] }

          # Set platform-specific variables that the executable will need.
          if (defined(platform_executable_variables)) {
            # Set the variables that wouldn't have been forwarded from the invoker.
            forward_variables_from(invoker.platform_executable_variables, "*", _variables_from_invoker)

            # For variables that might have been forwarded from the invoker, append to them instead of overwriting.
            if (defined(platform_executable_variables.deps)) {
              deps += platform_executable_variables.deps
            }
            if (defined(platform_executable_variables.public_deps)) {
              public_deps += platform_executable_variables.public_deps
            }
            if (defined(platform_executable_variables.cflags)) {
              cflags += platform_executable_variables.cflags
            }
            if (defined(platform_executable_variables.configs)) {
              configs += platform_executable_variables.configs
            }
          }

          # Set `output_name` if the platform exectuable needs it.
          if (!defined(platform_executable_output_name_suffix)) {
            platform_executable_output_name_suffix = ""
          }
          output_name = platform_executable_output_name + _test_name +
                        platform_executable_output_name_suffix

          print("CREATE ${pw_unit_test_EXECUTABLE_TARGET_TYPE}: ${output_name}")  # DEBUG

          # Add the individual test source file (e.g. "TestSomething.cpp")
          if (!defined(sources)) {
            sources = []
          }
          sources += [ _test ]

          output_dir = _test_output_dir

          if (current_os != "zephyr" && current_os != "mbed" &&
              chip_device_platform != "efr32") {
            # Depend on stdio logging, and have it take precedence over the default platform backend
            public_deps += [ "${chip_root}/src/platform/logging:stdio" ]
          } else {
            public_deps += [ "${chip_root}/src/platform/logging:default" ]
          }

        }
        tests += [ _test_name ]
      }

      group(_suite_name) {
        deps = []
        foreach(_test, tests) {
          deps += [ ":${_test}" ]
        }
      }

    } else {

      group(_suite_name) {
        deps = [ ":${_suite_name}.lib" ]
      }

    }
  }
}
